# =============================================================================
# Unified Local Development Environment Variables
# Copy this file to .env.local and fill in your actual values
# All services (www, email-worker) load from the root .env.local file
# =============================================================================

# -----------------------------------------------------------------------------
# Dev Server Ports
# -----------------------------------------------------------------------------
# Override these to avoid port conflicts when running multiple template-based
# projects simultaneously. Each project should use unique ports.
#
# Example port ranges for multiple projects:
#   Template:  WWW=1313, Worker=8787
#   Project A: WWW=1401, Worker=8801
#   Project B: WWW=1402, Worker=8802
WWW_PORT=1313
WORKER_PORT=8787