{
  "name": "gatezh-com-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["services/*"],
  "scripts": {
    "dev": "bun --env-file=.env.local run --parallel --filter '*' dev",
    "dev:www": "bun --env-file=.env.local --filter www dev",
    "dev:worker": "bun --env-file=.env.local --filter email-worker dev",
    "build": "bun --env-file=.env.local run --parallel --filter '*' build",
    "build:www": "bun --env-file=.env.local --filter www build",
    "build:worker": "bun --env-file=.env.local --filter email-worker build",
    "deploy:www": "bun --filter www deploy",
    "deploy:worker": "bun --filter email-worker deploy",
    "deploy": "bun run deploy:www && bun run deploy:worker",
    "typecheck": "bun --filter '*' typecheck",
    "format": "oxlint . --fix",
    "check": "bun lint && bun typecheck",
    "lint": "bun --filter '*' lint",
    "test": "bun run --cwd services/www test",
    "test:ui": "bun run --cwd services/www test:ui",
    "test:report": "bun run --cwd services/www test:report"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "22.19.15",
    "oxlint": "1.51.0",
    "typescript": "5.9.3",
    "wrangler": "4.71.0"
  }
}
