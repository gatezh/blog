{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "typescript": "warn",
    "import": "warn",
    "unicorn": "warn"
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/.wrangler",
    "**/coverage",
    "**/.vite",
    "**/*.min.js",
    "**/public",
    "services/www/themes",
    "services/www/static",
    "services/www/layouts",
    "services/www/content"
  ]
}
