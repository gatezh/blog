// For format details, see https://aka.ms/devcontainer.json
{
  "name": "Claude Code Sandbox",
  // Pre-built image from GitHub Container Registry (sandbox variant with firewall support)
  "image": "ghcr.io/gatezh/devcontainer-images/claude-code-sandbox:latest",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        // **Disabled user extensions** (prevent syncing from host)
        // GitHub Pull Requests - requires SSH keys not available in container
        "-github.vscode-pull-request-github",
        // **Theme**
        // Claude Theme - VS Code color theme by Sami Hindi
        "SamiHindi.claude-theme-sami-hindi",
        // **AI Agents**
        // Claude Code - AI-powered coding assistant
        "anthropic.claude-code",
        // **General**
        // OXC - Linting and formatting
        "oxc.oxc-vscode",
        // Code Spell Checker - Spell checking
        "streetsidesoftware.code-spell-checker",
        // YAML - YAML support
        "redhat.vscode-yaml",
        // Markdown Preview Github Styles - Markdown preview
        "bierner.markdown-preview-github-styles",
        // **JS/TS**
        // Bun - runtime and package manager support
        "oven.bun-vscode",
        // NPM Intellisense - NPM package intellisense
        "christian-kohler.npm-intellisense",
        // TS Error Translator - Translates TypeScript errors
        "mattpocock.ts-error-translator",
        // **CSS**
        // Tailwind CSS IntelliSense
        "bradlc.vscode-tailwindcss",
        // Tailwind Fold
        "stivo.tailwind-fold",
        // Color Info - Provides color information
        "bierner.color-info",
        // Colorize - Colorizes code
        "kamikillerto.vscode-colorize",
        // **Testing**
        // Playwright - E2E test runner and debugger
        "ms-playwright.playwright"
      ],
      "settings": {
        "window.title": "${localWorkspaceFolderBasename}",
        "workbench.colorTheme": "Claude Dark",
        "workbench.colorCustomizations": {
          "statusBarItem.remoteBackground": "#C15F3C",
          "statusBarItem.remoteForeground": "#ffffff"
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.oxc": "explicit",
          "source.organizeImports.oxc": "explicit"
        },
        // Hugo HTML templates use Go template syntax ({{ }}) - disable OXC formatting
        "[html]": {
          "editor.defaultFormatter": null,
          "editor.formatOnSave": false
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "containerEnv": {
    "TZ": "${localEnv:TZ:America/Edmonton}",
    "DEVCONTAINER": "true",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // Initialize Claude Code plugins (runs once when container is created)
  "postCreateCommand": "bun install && bash /workspace/.devcontainer/claude-code/init-plugins.sh",
  // Initialize firewall from bind-mounted workspace script
  "postStartCommand": "sudo bash /workspace/.devcontainer/claude-code/init-firewall.sh",
  "waitFor": "postStartCommand"
}
