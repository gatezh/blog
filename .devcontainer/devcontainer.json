// For format details, see https://aka.ms/devcontainer.json
{
  "name": "Local Development",
  // Pre-built image from GitHub Container Registry
  "image": "ghcr.io/gatezh/devcontainer-images/claude-code:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        // **Disabled user extensions** (prevent syncing from host)
        // GitHub Pull Requests - requires SSH keys not available in container
        "-github.vscode-pull-request-github",
        // **AI Agents**
        // Claude Code - AI-powered coding assistant
        "anthropic.claude-code",
        // **General**
        // OXC - Linting and formatting
        "oxc.oxc-vscode",
        // Code Spell Checker - Spell checking
        "streetsidesoftware.code-spell-checker",
        // YAML - YAML support
        "redhat.vscode-yaml",
        // Markdown Preview Github Styles - Markdown preview
        "bierner.markdown-preview-github-styles",
        // Docker extension
        "ms-azuretools.vscode-docker",
        // **JS/TS**
        // Bun - runtime and package manager support
        "oven.bun-vscode",
        // NPM Intellisense - NPM package intellisense
        "christian-kohler.npm-intellisense",
        // TS Error Translator - Translates TypeScript errors
        "mattpocock.ts-error-translator",
        // **Hugo**
        // Hugo language support
        "budparr.language-hugo-vscode",
        // Hugo shortcode syntax
        "kaellarkin.hugo-shortcode-syntax",
        // **CSS**
        // Tailwind CSS IntelliSense
        "bradlc.vscode-tailwindcss",
        // Tailwind Fold
        "stivo.tailwind-fold",
        // **Testing**
        // Playwright - E2E test runner and debugger
        "ms-playwright.playwright"
      ],
      "settings": {
        "window.title": "${localWorkspaceFolderBasename}",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.oxc": "explicit",
          "source.organizeImports.oxc": "explicit"
        },
        // Hugo HTML templates use Go template syntax ({{ }}) - disable OXC formatting
        "[html]": {
          "editor.defaultFormatter": null,
          "editor.formatOnSave": false
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=dev-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=dev-claude-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "containerEnv": {
    "TZ": "${localEnv:TZ:America/Edmonton}",
    "DEVCONTAINER": "true",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // Install dependencies and initialize Claude Code plugins
  "postCreateCommand": "bun install && bash .devcontainer/init-plugins.sh"
}
